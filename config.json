{
    "proxy": {
        "url": "http://127.0.0.1:7890",
        "rss": false,
        "bot": false
    },

    "rss": {
        "CustomRSS": {
            "enabled": true,
            "filename": "CustomRSS.opml"
        },
        "CyberSecurityRSS": {
            "enabled": true,
            "url": "https://raw.githubusercontent.com/zer0yu/CyberSecurityRSS/master/CyberSecurityRSS.opml",
            "filename": "CyberSecurityRSS.opml"
        },
        "Chinese-Security-RSS": {
            "enabled": true,
            "url": "https://raw.githubusercontent.com/zhengjim/Chinese-Security-RSS/master/Chinese-Security-RSS.opml",
            "filename": "Chinese-Security-RSS.opml"
        },
        "awesome-security-feed": {
            "enabled": true,
            "url": "https://raw.githubusercontent.com/mrtouch93/awesome-security-feed/main/security_feeds.opml",
            "filename": "awesome-security-feed.opml"
        },
        "wechatRSS": {
            "enabled": true,
            "url": "https://wechat2rss.xlab.app/opml/sec.opml",
            "filename": "wechatRSS.opml"
        }
    },

    "bot": {
        "feishu": {
            "enabled": false,
            "secrets": "FEISHU_KEY",
            "key": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
        }
    },

    "github": {
        "enabled": true,
        "token_env": "GITHUB_TOKEN",
        "token": "xxxx1",
        "owner": "xxxxx",
        "repo": "xxxx",
        "path": "today-{hour}.md",
        "branch": "main",
        "commit_message": "",
        "api_base": "https://api.github.com",
        "use_proxy": false,
        "sync_archive": true,
        "archive_path_pattern": "archive/{year}/{stamp}.md",
        "sync_archive_full": false
    },

    "deepseek": {
        "enabled": true,
        "api_key_env": "DEEPSEEK_API_KEY",
        "api_key": "xxxxxxx",
        "base_url": "https://api.deepseek.com/v1",
        "model": "deepseek-chat",
        "use_proxy": false,
        "static_prefilter": true,
        "max_context_tokens": 4096,
        "context_safety_margin": 120,
        "output_tokens_per_title": 32,
        "max_titles_per_batch": 28,
        "max_output_tokens_cap": 2048
    },

    "keywords": {
        "fetch_within_hours": 12,
        "exclude": [
            "招聘", "招生", "开班", "报名", "双非", "倒计时", "圆满", "抽奖",
            "好礼", "福利", "领取", "火热", "热烈", "欢迎", "美女",
            "喜报", "喜讯", "惊喜", "恭喜", "签约", "快乐", "颜值",
            "新冠", "疫情", "疫苗", "核酸",
            "月薪", "年薪"
        ],
        "static_non_security": [
            "阿贝尔奖", "莫德尔", "咖啡", "显示屏", "刷新率", "笔记本屏",
            "超加工食品", "生育能力", "耐抗生素", "干旱",
            "极客早知道", "打车，不只是", "WWDC", "定档",
            "星露谷", "魔兽", "徒步", "新能源车", "国产车",
            "Science", "诺贝尔", "物理学奖", "量子计算",
            "Arm公司宣布", "NASA", "月球", "空间站",
            " rtl-sdr", "天线", "短波", "收音机",
            "SCIOPERO", " giornalisti", "罗马", "记者罢工"
        ]
    }
}
